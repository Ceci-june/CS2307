# =============================================================================
# Real Estate Recommendation System — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# === PostgreSQL (pgvector) ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=real_estate
HOST_DB=postgres
PORT_DB=5432
USERNAME_DB=postgres
PASSWORD_DB=changeme
DATABASE=real_estate

# === MinIO (S3-compatible object storage) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_END_POINT=minio:9000
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_BUCKET_NAME=property-images
MINIO_SECURE=False

# === Neo4j (graph database) ===
NEO4J_AUTH=neo4j/changeme
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# === Application ===
DEBUG=False
VERSION=1.0.0
PROJECT_NAME=real-estate-recommendation-system
CORS_ORIGINS=http://localhost:3000

# === Google Gemini LLM ===
# Comma-separated API keys for load balancing
GEMINI_API_KEYS=your-gemini-api-key-here

# === Auth (loaded by config, not actively used in current endpoints) ===
ACCESS_TOKEN_SECRET_KEY=change-this-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_SECRET_KEY=change-this-to-a-random-secret
REFRESH_TOKEN_EXPIRE_MINUTES=10080
